# Churn ML Project – Environment Variables
# Copy this file to .env and adjust values if needed.
# The application reads these via os.getenv() in src/config.py.

# ── Data paths ────────────────────────────────────────────────────────────────
CHURN_RAW_DATA_PATH=data/raw/churn.csv

# ── Artifact paths ────────────────────────────────────────────────────────────
CHURN_MODEL_PATH=models/best_model.joblib
CHURN_METRICS_PATH=models/model_metrics.json
CHURN_FEATURE_COLUMNS_PATH=models/feature_columns.json
CHURN_MODEL_METADATA_PATH=models/model_metadata.json
CHURN_TRAINING_BASELINE_PATH=models/training_baseline.json
CHURN_PREDICTION_LOG_PATH=logs/predictions.jsonl
CHURN_PREDICTION_LOG_MAX_BYTES=1048576
CHURN_PREDICTION_LOG_BACKUP_COUNT=5

# ── Training hyperparameters ──────────────────────────────────────────────────
CHURN_RANDOM_STATE=42
CHURN_TEST_SIZE=0.2

# ── Experiment tracking ───────────────────────────────────────────────────────
CHURN_ENABLE_MLFLOW=1
CHURN_MLFLOW_TRACKING_URI=mlruns
CHURN_MLFLOW_EXPERIMENT_NAME=telecom-churn
CHURN_MLFLOW_LOG_MODEL=0

# ── API hardening ─────────────────────────────────────────────────────────────
CHURN_REDIS_URL=
CHURN_API_KEY=
CHURN_API_RATE_LIMIT=60
CHURN_API_RATE_LIMIT_WINDOW_SECONDS=60
